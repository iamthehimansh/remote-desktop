# pi-dash environment — copy to .env and fill in.
JWT_SECRET=        # random 64-char hex (auto-generated if empty, but persists if set)
COOKIE_SUFFIX=     # random 6-char hex — isolates from any other cookie

# Cloudflare (for managing ingress + DNS from the dashboard)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
TUNNEL_ID=           # the pi-dash tunnel UUID

# Wake-on-LAN target
PC_MAC=
PC_IP=

# Files (where the file browser is rooted)
FILE_ROOT=/home/pi

# ttyd port (terminal)
TTYD_PORT=7681
